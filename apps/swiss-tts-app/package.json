{
  "name": "swiss-tts-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "jest --coverage"
  },
  "dependencies": {
    "@react-native-picker/picker": "2.11.1",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-av": "~16.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.86.0",
    "react-native-url-polyfill": "^3.0.0",
    "syncpack": "^15.3.2"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^54.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "prettier": "^3.0.0",
    "react-test-renderer": "19.1.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
