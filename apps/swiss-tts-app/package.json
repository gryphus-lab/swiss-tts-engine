{
  "name": "swiss-tts-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "build:android:preview:local": "eas build -p android --profile preview --local",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "jest --coverage"
  },
  "dependencies": {
    "@react-native-picker/picker": "2.11.4",
    "@react-native/jest-preset": "^0.86.0",
    "expo": "~56.0.12",
    "expo-asset": "~56.0.17",
    "expo-audio": "^56.0.12",
    "expo-build-properties": "~56.0.19",
    "expo-file-system": "~56.0.8",
    "expo-status-bar": "~56.0.4",
    "llama.rn": "^0.12.5",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-url-polyfill": "^3.0.0",
    "syncpack": "^15.3.2"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.1",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~56.0.15",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "prettier": "^3.0.0",
    "react-test-renderer": "19.2.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@react-native-picker)"
    ]
  },
  "private": true
}
